{
  "name": "agents-desktop",
  "version": "0.1.0",
  "description": "TypeScript + Electron + LangChain Agent desktop",
  "main": "dist-electron/main.js",
  "scripts": {
    "test": "vitest run",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write src/**/*.{ts,vue}",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.34.4",
  "private": "true",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4"
  }
}
